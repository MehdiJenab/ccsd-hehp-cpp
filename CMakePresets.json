{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER": "mpicxx"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "release",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "asan",
      "inherits": "debug",
      "cacheVariables": {
        "CCSD_ENABLE_ASAN": "ON",
        "CCSD_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "tsan",
      "inherits": "debug",
      "cacheVariables": { "CCSD_ENABLE_TSAN": "ON" }
    },
    {
      "name": "coverage",
      "inherits": "debug",
      "cacheVariables": { "CCSD_ENABLE_COVERAGE": "ON" }
    },
    {
      "name": "release-gprof",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CCSD_ENABLE_GPROF": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",    "configurePreset": "debug" },
    { "name": "release",  "configurePreset": "release" },
    { "name": "asan",     "configurePreset": "asan" },
    { "name": "tsan",     "configurePreset": "tsan" },
    { "name": "coverage", "configurePreset": "coverage" },
    { "name": "release-gprof", "configurePreset": "release-gprof" }
  ],
  "testPresets": [
    { "name": "debug",    "configurePreset": "debug",    "output": { "outputOnFailure": true } },
    { "name": "asan",     "configurePreset": "asan",     "output": { "outputOnFailure": true } },
    { "name": "coverage", "configurePreset": "coverage", "output": { "outputOnFailure": true } }
  ]
}
