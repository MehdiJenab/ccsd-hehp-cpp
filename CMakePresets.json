{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER": "mpicxx"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "release",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "release-fast",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -march=native -flto -DNDEBUG",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-flto",
        "CMAKE_SHARED_LINKER_FLAGS_RELEASE": "-flto",
        "CMAKE_MODULE_LINKER_FLAGS_RELEASE": "-flto"
      }
    },
    {
      "name": "asan",
      "inherits": "debug",
      "cacheVariables": {
        "CCSD_ENABLE_ASAN": "ON",
        "CCSD_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "tsan",
      "inherits": "debug",
      "cacheVariables": { "CCSD_ENABLE_TSAN": "ON" }
    },
    {
      "name": "coverage",
      "inherits": "debug",
      "cacheVariables": { "CCSD_ENABLE_COVERAGE": "ON" }
    },
    {
      "name": "release-gprof",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CCSD_ENABLE_GPROF": "ON"
      }
    },
    {
      "name": "release-fast-instrument",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -march=native -flto -fprofile-generate=${sourceDir}/build/pgo-data -DNDEBUG",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-fprofile-generate=${sourceDir}/build/pgo-data"
      }
    },
    {
      "name": "release-fast-pgo",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -march=native -flto -fprofile-use=${sourceDir}/build/pgo-data -fprofile-correction -DNDEBUG",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-fprofile-use=${sourceDir}/build/pgo-data -fprofile-correction"
      }
    },
    {
      "name": "release-mdspan",
      "inherits": "release-fast",
      "cacheVariables": { "CCSD_USE_MDSPAN": "ON" }
    },
    {
      "name": "release-mdspan-rowmajor",
      "inherits": "release-mdspan",
      "cacheVariables": { "CCSD_LAYOUT_ROW_MAJOR": "ON" }
    }
  ],
  "buildPresets": [
    { "name": "debug",    "configurePreset": "debug" },
    { "name": "release",  "configurePreset": "release" },
    { "name": "asan",     "configurePreset": "asan" },
    { "name": "tsan",     "configurePreset": "tsan" },
    { "name": "coverage", "configurePreset": "coverage" },
    { "name": "release-gprof", "configurePreset": "release-gprof" },
    { "name": "release-fast", "configurePreset": "release-fast" },
    { "name": "release-fast-instrument", "configurePreset": "release-fast-instrument" },
    { "name": "release-fast-pgo", "configurePreset": "release-fast-pgo" },
    { "name": "release-mdspan", "configurePreset": "release-mdspan" },
    { "name": "release-mdspan-rowmajor", "configurePreset": "release-mdspan-rowmajor" }
  ],
  "testPresets": [
    { "name": "debug",    "configurePreset": "debug",    "output": { "outputOnFailure": true } },
    { "name": "asan",     "configurePreset": "asan",     "output": { "outputOnFailure": true } },
    { "name": "coverage", "configurePreset": "coverage", "output": { "outputOnFailure": true } },
    { "name": "release-fast", "configurePreset": "release-fast", "output": { "outputOnFailure": true } },
    { "name": "release-mdspan", "configurePreset": "release-mdspan", "output": { "outputOnFailure": true } },
    { "name": "release-mdspan-rowmajor", "configurePreset": "release-mdspan-rowmajor", "output": { "outputOnFailure": true } }
  ]
}
